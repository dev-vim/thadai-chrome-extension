  "version": "0.0.1",
  "author": "**",
  "description": "A productivity-focused Chrome extension that blocks distracting websites and uses an Ethereum smart contract as an access control engine.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "thadai-chrome-extension",
    "vanilla",
    "vite",
    "create-chrome-ext"
  ],
  "engines": {
    "node": ">=14.18.0"
  },
  "scripts": {
