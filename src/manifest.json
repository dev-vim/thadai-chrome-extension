{
    "name": "Thadai Chrome Extension",
    "version": "0.0.1",
    "manifest_version": 3,
    "description": "Improve your productivity!",
    "action": {
        "default_popup": "popup/popup.html"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content/content-script.js"]
        }
    ],
    "background": {
        "service_worker": "background/background-worker.js"
    },
    "permissions": [
        "tabs",
        "storage"
    ]
}